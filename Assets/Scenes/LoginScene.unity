  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ada7a567de087ef4b80bcb4c4d352a83, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  noticePanel: {fileID: 949761697}
  openButton: {fileID: 560769136}
  closeButton: {fileID: 59872091}
  noticeText: {fileID: 811145374}
  noticeContent: "\uC548\uB155\uD558\uC2ED\uB2C8\uAE4C! \uBAA8\uD5D8\uAC00 \uC5EC\uB7EC\uBD84\n\uBB34\uD55C\uB808\uBCA8\uC5C5\uC5D0
    \uC624\uC2E0\uAC83\uC744 \uD658\uC601\uD569\uB2C8\uB2E4.\n\uACFC\uAE08 \uC5C6\uC774
    \uBAA8\uB4E0 \uAC8C\uC784\uC758 \uC7AC\uBBF8\uC788\uB294 \uAC83\uC744 \uC990\uAE30\uC138\uC694.
    \n\uC870\uC791\uBC95\uC740 \uAC04\uB2E8\uD569\uB2C8\uB2E4. \uD0C0\uC6CC \uB514\uD39C\uC2A4
    \n\uAC8C\uC784\uC774\uAE30 \uB54C\uBB38\uC5D0 \uC6C0\uC9C1\uC774\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4.\nUI\uB4E4\uC744
    \uD130\uCE58(\uD074\uB9AD)\uD558\uAE30\uB9CC \uD558\uC2DC\uBA74 \uB429\uB2C8\uB2E4.\n\n[2026.4.1
    \uC5C5\uB370\uC774\uD2B8 \uB0B4\uC6A9]\n\uB208\uC5D0 \uBCF4\uC774\uB294 \uBC84\uADF8\uB4E4\uC744
    \uC218\uC815\uD560 \uC608\uC815\uC785\uB2C8\uB2E4.\n\uB3D9\uB8CC\uBF51\uAE30\uAC00
    \uCD94\uAC00\uB420 \uC608\uC815\uC785\uB2C8\uB2E4.\n\uC774\uBCA4\uD2B8 \uC2DC\uC2A4\uD15C\uC774
    \uCD94\uAC00\uB420 \uC608\uC815\uC785\uB2C8\uB2E4.\n\uACFC\uAE08\uB7EC\uC640
    \uBB34\uACFC\uAE08\uB7EC\uC758 \uC870\uD654 \uC2DC\uC2A4\uD15C\n\uBAAC\uC2A4\uD130
    \uCE74\uB4DC, \uCE74\uB4DC \uC870\uD569\uBC95 \uCD94\uAC00\uC608\uC815\n\uCE90\uB9AD\uD130
    \uC77C\uB7EC\uC2A4\uD2B8\uB97C \uB354 \uC608\uC058\uAC8C \uD560\uC608\uC815\n2D
    \uCE90\uB9AD\uD130\uAC00 \uBA4B\uC9C4 \uC7A5\uBE44\uB97C \uB4E4\uACE0 \uC2F8\uC6B0\uAC8C\uD560
    \uC608\uC815\n"
